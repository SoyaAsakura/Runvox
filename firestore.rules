rules_version = '2';

// Runvox Firestore セキュリティルール
//
// Firebase コンソール or `firebase deploy --only firestore:rules` で適用する。
// 現状は users コレクションのみ実装。questions / answers などは各 Repository の
// Firestore 実装 PR で順次ルールを追加する。

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== users =====
    // - 読み取り: 認証済みユーザーなら誰でも可（回答者プロフィール閲覧のため）
    // - 作成/更新: 本人のみ
    // - 削除: 不可（退会は将来の専用フローで対応）
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // ===== questions =====
    // - 読み取り: 認証済みユーザーなら誰でも可（一覧 / 詳細 / 検索）
    // - 作成: 本人（askerId == uid）が、必須フィールドを揃えて作成する場合のみ
    // - 更新: MVP では認証済みなら許可（回答投稿時に回答者が status / latestAnswerer を
    //         更新するため）。将来は Cloud Functions 経由に絞って厳格化する。
    // - 削除: 質問者本人のみ
    match /questions/{questionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.askerId
        && request.resource.data.title is string
        && request.resource.data.body is string
        && request.resource.data.category is string;
      allow update: if request.auth != null;
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.askerId;
    }

    // ===== answers =====
    // - 読み取り: 認証済みユーザーなら誰でも可（質問詳細での回答表示）
    // - 作成: 本人（answererId == uid）が、必須フィールドを揃えて作成する場合のみ。
    //         postAnswer の Transaction 内で questions ドキュメントの update と
    //         同時に書き込まれる（先着 1 名判定はサーバ側 Transaction で担保）。
    // - 更新: MVP では認証済みなら許可（★評価の rating 反映用。将来は厳格化）。
    // - 削除: 不可。
    match /answers/{answerId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.answererId
        && request.resource.data.questionId is string
        && request.resource.data.body is string;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // ===== pointTransactions =====
    // ポイント付与履歴（userId = 受領者 = 回答者）。
    // - 読み取り: 本人（受領者）のみ（ダッシュボードで自分の履歴を見る）
    // - 作成: MVP では認証済みなら許可（評価者が回答者宛に作成するため）。
    //   ⚠️ 本番は Cloud Functions（Admin）に限定して改ざん防止する。
    // - 更新 / 削除: 不可（履歴は不変）
    match /pointTransactions/{txId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // ===== userPoints =====
    // ポイント残高サマリ（ドキュメント ID = userId）。
    // - 読み取り: 本人のみ（残高は非公開）
    // - 作成 / 更新: MVP では認証済みなら許可（評価者が回答者の残高を加算するため）。
    //   ⚠️ 本番は Cloud Functions（Admin）に限定すること。
    // - 削除: 不可
    match /userPoints/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null;
      allow delete: if false;
    }

    // ===== notifications =====
    // - 読み取り: 本人宛のみ
    // - 作成: Cloud Functions（Admin）のみ。クライアントからは作らない。
    // - 更新: 本人のみ（既読化を想定）
    // - 削除: 不可
    match /notifications/{notificationId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if false;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId;
      allow delete: if false;
    }

    // ===== reports =====
    // 通報はモデレーション用。クライアントからの読み取りは不可（Admin のみ）。
    // - 作成: 本人（reporterId == uid）が必須項目を揃える場合のみ
    // - 更新 / 削除: 不可
    match /reports/{reportId} {
      allow read: if false;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.reporterId
        && request.resource.data.targetId is string
        && request.resource.data.reason is string;
      allow update, delete: if false;
    }

    // ===== reviewerApplications =====
    // - 読み取り: 本人のみ（自分の申請ステータス確認）
    // - 作成: 本人（userId == uid）が必須項目を揃える場合のみ
    // - 更新（審査結果の status 変更）/ 削除: 運営（Admin）のみ → クライアントは不可
    match /reviewerApplications/{applicationId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId
        && request.resource.data.achievements is string;
      allow update, delete: if false;
    }

    // ===== それ以外 =====
    // 明示的に許可していないコレクションは全拒否。
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
